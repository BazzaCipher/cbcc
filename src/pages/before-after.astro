---
// Standalone preview of the Before/After slider — no CMS/Sanity required.
// The same <BeforeAfter> component also works as a Sanity `beforeAfterSection`.
import BeforeAfter from '@components/BeforeAfter.astro';
import '../styles/globals.css';

const beforeImage = {
    src: '/before.png',
    alt: 'Corrugated fence covered in black graffiti',
    dimensions: { width: 989, height: 618 }
};
const afterImage = {
    src: '/after.png',
    alt: 'The same fence cleaned and restored',
    dimensions: { width: 1306, height: 816 }
};
---

<!doctype html>
<html lang="en" data-theme="light">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
        <title>Before / After — CBCC</title>
        <meta name="robots" content="noindex" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=Mulish:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet" />
    </head>
    <body class="antialiased">
        <BeforeAfter
            heading="See the difference"
            body="Drag the slider to compare the fence before and after."
            beforeImage={beforeImage}
            afterImage={afterImage}
        />
    </body>
</html>
