---
import { marked } from 'marked';
import Section from '@components/Section.astro';
import BeforeAfter from '@components/BeforeAfter.astro';

/*
 * "See the difference" from the Collimated Beam design: eyebrow + heading +
 * body over a grid of interactive before/after comparison cards. Each item is a
 * `beforeAfter` (two Sanity images the slider wipes between) with an optional
 * title + caption. A single item is centred and widened; multiples form a grid.
 */
interface ImageInput {
    _id?: string;
    src: string;
    alt?: string;
    dimensions?: { width: number; height: number };
}
interface Item {
    title?: string;
    caption?: string;
    beforeImage: ImageInput;
    afterImage: ImageInput;
    beforeLabel?: string;
    afterLabel?: string;
}
interface Props {
    eyebrow?: string;
    heading?: string;
    body?: string;
    items?: Array<Item>;
    'data-sb-field-path'?: string;
}

const { eyebrow, heading, body, items = [], 'data-sb-field-path': fieldPath } = Astro.props;
const single = items.length === 1;
---

<section id="work" class="relative w-full px-3 py-16 sm:px-6 sm:py-28" data-sb-field-path={fieldPath}>
    <div class="relative mx-auto max-w-7xl" data-reveal>
        {eyebrow && <span class="cb-eyebrow" data-sb-field-path=".eyebrow">{eyebrow}</span>}
        {
            heading && (
                <h2 class="mt-3 text-3xl font-black tracking-tight sm:text-5xl text-balance" data-sb-field-path=".heading">
                    {heading}
                    <span class="beam-underline" aria-hidden="true" />
                </h2>
            )
        }
        {body && <div class="mt-5 max-w-prose text-base-content/75 markdown" data-sb-field-path=".body" set:html={marked.parse(body)} />}

        {
            items.length > 0 && (
                <div
                    class:list={['mt-12 grid gap-6 items-start', single ? 'mx-auto w-full max-w-5xl' : 'md:grid-cols-2 lg:grid-cols-3']}
                    data-sb-field-path=".items"
                >
                    {items.map((item, idx) => (
                        <figure class="m-0" data-reveal style={{ '--reveal-delay': `${idx * 0.08}s` }} data-sb-field-path={`.${idx}`}>
                            <BeforeAfter
                                beforeImage={item.beforeImage}
                                afterImage={item.afterImage}
                                beforeLabel={item.beforeLabel}
                                afterLabel={item.afterLabel}
                            />
                            {(item.title || item.caption) && (
                                <figcaption class="mt-4">
                                    {item.title && (
                                        <h3 class="text-lg font-bold tracking-tight" data-sb-field-path=".title">
                                            {item.title}
                                        </h3>
                                    )}
                                    {item.caption && (
                                        <p class="mt-1 text-sm text-base-content/70" data-sb-field-path=".caption">
                                            {item.caption}
                                        </p>
                                    )}
                                </figcaption>
                            )}
                        </figure>
                    ))}
                </div>
            )
        }
    </div>
</section>
