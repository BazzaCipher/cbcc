---
import { marked } from 'marked';
import { type HeroSection } from 'types';
import Action from '@components/Action.astro';

/*
 * Hero from the Collimated Beam design: a dark "chamber" band — eyebrow +
 * headline + body + two CTAs over faint scan-lines and one glowing beamline —
 * followed by a full-bleed result photo that fades in from the band above.
 * Pinned dark in both page themes, matching the design's fixed section rhythm.
 */
interface ImageInput {
    _id?: string;
    src: string;
    alt?: string;
    dimensions?: { width: number; height: number };
}
interface Props extends HeroSection {
    eyebrow?: string;
    image?: ImageInput;
    'data-sb-field-path'?: string;
}

const { eyebrow, heading, body, cta, image, 'data-sb-field-path': fieldPath } = Astro.props;
// Design-system kicker; falls back when the CMS field is empty. Safe to change.
const kicker = eyebrow || 'Precision laser cleaning';
---

<section class="w-full" data-theme="dark" data-sb-field-path={fieldPath}>
    <div class="hero-chamber relative overflow-hidden bg-base-100">
        <div class="hero-lines" aria-hidden="true"></div>
        <div class="hero-beamline" aria-hidden="true"></div>

        <div class="relative mx-auto max-w-4xl px-5 pt-24 pb-14 text-center sm:px-8 sm:pt-32 sm:pb-16">
            {kicker && <span class="cb-eyebrow hero-rise" style={{ '--rise-delay': '0.1s' }} data-sb-field-path=".eyebrow">{kicker}</span>}
            {
                heading && (
                    <h1
                        class="mt-5 text-5xl font-black tracking-tight sm:text-7xl text-balance hero-rise"
                        style={{ '--rise-delay': '0.25s' }}
                        data-sb-field-path=".heading"
                    >
                        {heading}
                    </h1>
                )
            }
            {
                body && (
                    <div
                        class:list={[heading && 'mt-6', 'mx-auto max-w-xl text-lg text-base-content/75 markdown hero-rise']}
                        style={{ '--rise-delay': '0.4s' }}
                        data-sb-field-path=".body"
                        set:html={marked.parse(body)}
                    />
                )
            }
            {
                cta && cta.length > 0 && (
                    <div
                        class:list={[(heading || body) && 'mt-10', 'flex flex-wrap items-center justify-center gap-4 hero-rise']}
                        style={{ '--rise-delay': '0.6s' }}
                        data-sb-field-path=".cta"
                    >
                        {cta.map((item, index) => (
                            <Action
                                action={item}
                                class:list={[item._type === 'actionLink' && 'font-bold underline hover:no-underline', 'btn-lg']}
                                data-sb-field-path={`.${index}`}
                            />
                        ))}
                    </div>
                )
            }
        </div>
    </div>

    {
        image && image.src && (
            <div class="hero-photo-wrap" data-sb-field-path=".image">
                <img class="hero-photo" src={image.src} alt={image.alt || ''} draggable="false" />
                <div class="hero-photo-fade" aria-hidden="true" />
            </div>
        )
    }
</section>

<style>
    /* Faint horizontal scan lines across the chamber */
    .hero-lines {
        position: absolute;
        inset: 0;
        pointer-events: none;
        opacity: 0.5;
        background-image: repeating-linear-gradient(180deg, transparent 0 83px, rgb(255 255 255 / 0.045) 83px 84px);
    }
    /* The signature: one glowing horizontal laser line behind the headline */
    .hero-beamline {
        position: absolute;
        left: 0;
        right: 0;
        top: 48%;
        height: 2px;
        pointer-events: none;
        background: linear-gradient(90deg, transparent, var(--color-primary) 30%, #ff6a47 70%, transparent);
        box-shadow: 0 0 26px 4px color-mix(in oklab, var(--color-primary) 45%, transparent);
    }
    @media (prefers-reduced-motion: no-preference) {
        @keyframes beamline-in {
            from {
                opacity: 0;
                transform: scaleX(0.2);
            }
            to {
                opacity: 1;
                transform: scaleX(1);
            }
        }
        .hero-beamline {
            transform-origin: center;
            animation: beamline-in 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
        }
    }

    /* Full-bleed result photo below the chamber, fading in from the band above */
    .hero-photo-wrap {
        position: relative;
        height: 400px;
        overflow: hidden;
        background: var(--color-base-200);
    }
    .hero-photo {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .hero-photo-fade {
        position: absolute;
        inset: 0;
        pointer-events: none;
        background: linear-gradient(180deg, var(--color-base-100), transparent 22%);
    }
    @media (max-width: 640px) {
        .hero-photo-wrap {
            height: 260px;
        }
    }
</style>
