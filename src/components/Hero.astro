---
import { marked } from 'marked';
import { type HeroSection } from 'types';
import Action from '@components/Action.astro';
import BeforeAfter from '@components/BeforeAfter.astro';

// The before/after comparison is a home-hero feature, driven by local assets.
const beforeImage = { src: '/before.png', alt: 'Fence covered in graffiti', dimensions: { width: 989, height: 618 } };
const afterImage = { src: '/after.png', alt: 'The same fence cleaned and restored', dimensions: { width: 1306, height: 816 } };

interface Props extends HeroSection {
    'data-sb-field-path'?: string;
}

/* The hero is a dark "chamber" scope in both page themes (matching the
   Collimated Beam design system), so it pins data-theme="dark". Sanity's
   per-hero `theme` and background image are intentionally not used here —
   the visual is the interactive before/after below the headline. */
const { heading, body, cta, width, 'data-sb-field-path': fieldPath } = Astro.props;
const inset = width === 'inset';
// Eyebrow kicker — design-system label, not CMS copy. Descriptive, safe to change.
const eyebrow = 'Precision laser cleaning';
---

<section class:list={['w-full', inset && 'px-3 sm:px-6']} data-sb-field-path={fieldPath}>
    <div
        class:list={[
            'relative overflow-hidden bg-base-100',
            inset ? 'mx-auto max-w-7xl rounded-box border border-base-content/8' : ''
        ]}
        data-theme="dark"
    >
        <div class="hero-lines" aria-hidden="true"></div>
        <div class="hero-beamline" aria-hidden="true"></div>

        <div class="relative mx-auto max-w-4xl px-5 pt-24 pb-14 text-center sm:px-8 sm:pt-32 sm:pb-16">
            <span class="cb-eyebrow hero-rise" style={{ '--rise-delay': '0.1s' }}>{eyebrow}</span>
            {
                heading && (
                    <h1
                        class="mt-5 text-5xl font-black tracking-tight sm:text-7xl text-balance hero-rise"
                        style={{ '--rise-delay': '0.25s' }}
                        data-sb-field-path=".heading"
                    >
                        {heading}
                    </h1>
                )
            }
            {
                body && (
                    <div
                        class:list={[heading && 'mt-6', 'mx-auto max-w-xl text-lg text-base-content/75 markdown hero-rise']}
                        style={{ '--rise-delay': '0.4s' }}
                        data-sb-field-path=".body"
                        set:html={marked.parse(body)}
                    />
                )
            }
            {
                cta && cta.length > 0 && (
                    <div
                        class:list={[(heading || body) && 'mt-10', 'flex flex-wrap items-center justify-center gap-4 hero-rise']}
                        style={{ '--rise-delay': '0.6s' }}
                        data-sb-field-path=".cta"
                    >
                        {cta.map((item, index) => (
                            <Action
                                action={item}
                                class:list={[item._type === 'actionLink' && 'font-bold underline hover:no-underline', 'btn-lg']}
                                data-sb-field-path={`.${index}`}
                            />
                        ))}
                    </div>
                )
            }
        </div>

        <div
            class="relative mx-auto max-w-5xl px-5 pb-20 sm:px-8 sm:pb-24 hero-rise"
            style={{ '--rise-delay': '0.75s' }}
        >
            <BeforeAfter beforeImage={beforeImage} afterImage={afterImage} />
        </div>
    </div>
</section>

<style>
    /* Faint horizontal scan lines across the chamber */
    .hero-lines {
        position: absolute;
        inset: 0;
        pointer-events: none;
        opacity: 0.5;
        background-image: repeating-linear-gradient(
            180deg,
            transparent 0 83px,
            rgb(255 255 255 / 0.045) 83px 84px
        );
    }
    /* The signature: one glowing horizontal laser line behind the headline */
    .hero-beamline {
        position: absolute;
        left: 0;
        right: 0;
        top: 30%;
        height: 2px;
        pointer-events: none;
        background: linear-gradient(
            90deg,
            transparent,
            var(--color-primary) 30%,
            #ff6a47 70%,
            transparent
        );
        box-shadow: 0 0 26px 4px color-mix(in oklab, var(--color-primary) 45%, transparent);
    }
    @media (prefers-reduced-motion: no-preference) {
        @keyframes beamline-in {
            from {
                opacity: 0;
                transform: scaleX(0.2);
            }
            to {
                opacity: 1;
                transform: scaleX(1);
            }
        }
        .hero-beamline {
            transform-origin: center;
            animation: beamline-in 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
        }
    }
</style>
