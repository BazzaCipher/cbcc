---
import { marked } from 'marked';
import { type CtaSection } from 'types';
import Action from '@components/Action.astro';
import Section from '@components/Section.astro';

interface Props extends CtaSection {
    'data-sb-field-path'?: string;
}

const { heading, body, cta, ...rest } = Astro.props;
---

<Section {...rest}>
    <div class="relative px-6 py-14 overflow-hidden text-center border rounded-box border-base-content/10 bg-base-200 sm:px-16 sm:py-20 cta-panel">
        {
            heading && (
                <h2 class="text-3xl font-black tracking-tight sm:text-5xl text-balance" data-sb-field-path=".heading">
                    {heading}
                </h2>
            )
        }
        {
            body && (
                <div
                    class:list={['mx-auto', heading && 'mt-4', 'max-w-prose text-base-content/75 markdown']}
                    data-sb-field-path=".body"
                    set:html={marked.parse(body)}
                />
            )
        }
        {
            cta && cta.length > 0 && (
                <div class:list={[(heading || body) && 'mt-8', 'flex flex-wrap items-center justify-center gap-4']} data-sb-field-path=".cta">
                    {cta.map((item, index) => (
                        <Action
                            action={item}
                            class:list={[item._type === 'text' && 'font-bold underline hover:no-underline', 'btn-lg']}
                            data-sb-field-path={`.${index}`}
                        />
                    ))}
                </div>
            )
        }
    </div>
</Section>

<style>
    /* Laser edge along the top of the panel */
    .cta-panel::before {
        content: '';
        position: absolute;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        width: min(24rem, 60%);
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--color-primary), transparent);
        box-shadow: 0 0 16px color-mix(in oklab, var(--color-primary) 50%, transparent);
    }
</style>
