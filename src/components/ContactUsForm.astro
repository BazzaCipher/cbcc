---
import { type ContactUsSection } from 'types';
import Section from '@components/Section.astro';

interface Props extends ContactUsSection {
    'data-sb-field-path'?: string;
}

const {
    title = 'Contact Us',
    subtitle = 'We’d love to hear from you. Please fill out the form below.',
    formAction = 'https://api.web3forms.com/submit',
    'data-sb-field-path': fieldPath
} = Astro.props as Props;
---

<Section data-sb-field-path={fieldPath}>
    <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-black tracking-tight text-center sm:text-5xl text-balance">{title}</h2>
        <p class="mt-4 text-center text-base-content/75">{subtitle}</p>

        <form action={formAction} method="POST" class="grid gap-6 mt-12" id="contact-form" data-max-size-mb="5">
            <div id="form-message" class="hidden text-center" role="status" aria-live="polite">
                <p id="form-message-text" class="font-medium"></p>
            </div>

            <div class="grid gap-6 md:grid-cols-2">
                <label class="grid gap-2">
                    <span class="text-sm font-medium">Name</span>
                    <input type="text" name="name" autocomplete="name" required class="w-full input input-bordered" />
                </label>
                <label class="grid gap-2">
                    <span class="text-sm font-medium">Email</span>
                    <input type="email" name="Email Address" autocomplete="email" required class="w-full input input-bordered" />
                </label>
                <label class="grid gap-2">
                    <span class="text-sm font-medium">Phone number <span class="font-normal text-base-content/50">(optional)</span></span>
                    <input type="tel" name="Phone Number" autocomplete="tel" pattern="[0-9+ ]+" class="w-full input input-bordered" />
                </label>
                <label class="grid gap-2">
                    <span class="text-sm font-medium">Postcode <span class="font-normal text-base-content/50">(optional)</span></span>
                    <input type="text" name="Postcode" autocomplete="postal-code" pattern="[0-9]{4}" class="w-full input input-bordered" />
                </label>
            </div>

            <label class="grid gap-2">
                <span class="text-sm font-medium">Your message</span>
                <textarea name="message" rows="6" required class="w-full textarea textarea-bordered"></textarea>
            </label>

            <div>
                <label for="attachment" class="block text-sm font-medium">
                    Photos of the surface <span class="font-normal text-base-content/50">(optional, helps us quote faster)</span>
                </label>
                <div
                    id="dropzone"
                    class="flex justify-center px-6 py-10 mt-2 transition border border-dashed rounded-box border-base-content/25 hover:border-primary/60 focus-within:border-primary"
                >
                    <div class="text-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 mx-auto text-base-content/50" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path stroke-width="1.5" d="M12 16V4m0 0 3.5 3.5M12 4 8.5 7.5M4 16v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" />
                        </svg>
                        <div class="flex items-center justify-center mt-4 text-sm">
                            <label for="attachment" class="relative px-2 py-1 font-semibold rounded-md cursor-pointer text-primary hover:underline">
                                <span>Upload a file</span>
                                <input
                                    id="attachment"
                                    name="attachment"
                                    type="file"
                                    class="sr-only"
                                    multiple
                                    accept=".pdf,.jpg,.jpeg,.png,.heic,.webp"
                                />
                            </label>
                            <p class="text-base-content/60">or drag &amp; drop</p>
                        </div>
                        <p class="mt-2 text-xs text-base-content/50">PDF, PNG, JPG. Up to 5MB.</p>
                        <p id="file-name" class="hidden mt-3 text-sm"></p>
                        <p id="file-error" class="hidden mt-2 text-sm text-error"></p>
                    </div>
                </div>
            </div>

            <div class="text-center">
                <button type="submit" class="px-10 btn btn-primary btn-lg">Send message</button>
            </div>

            <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />
        </form>
    </div>
</Section>

<script is:inline>
    (function () {
        const form = document.getElementById('contact-form');
        if (!form) return;
        const MAX_SIZE_MB = Number(form.dataset.maxSizeMb) || 5;
        const msgBox = document.getElementById('form-message');
        const msgText = document.getElementById('form-message-text');
        const input = document.getElementById('attachment');
        const dropzone = document.getElementById('dropzone');
        const fileName = document.getElementById('file-name');
        const fileError = document.getElementById('file-error');

        function showMessage(text, ok) {
            msgText.textContent = text;
            msgText.className = ok ? 'font-medium text-success' : 'font-medium text-error';
            msgBox.classList.remove('hidden');
        }

        function resetMessages() {
            fileError.classList.add('hidden');
            fileName.classList.add('hidden');
        }

        function showFile(file) {
            resetMessages();
            if (!file) return;
            const sizeMB = file.size / 1024 / 1024;
            if (sizeMB > MAX_SIZE_MB) {
                fileError.textContent = `File is too large (${sizeMB.toFixed(1)}MB). Max allowed is ${MAX_SIZE_MB}MB.`;
                fileError.classList.remove('hidden');
                input.value = '';
                return;
            }
            fileName.textContent = `${file.name} • ${sizeMB.toFixed(1)}MB`;
            fileName.classList.remove('hidden');
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const file = input.files && input.files[0];
            if (file && file.size / 1024 / 1024 > MAX_SIZE_MB) {
                showFile(file);
                return;
            }

            const submitBtn = form.querySelector('button[type="submit"]');
            submitBtn.disabled = true;

            try {
                const response = await fetch(form.action, {
                    method: 'POST',
                    headers: { Accept: 'application/json' },
                    body: new FormData(form)
                });

                if (response.ok) {
                    form.reset();
                    resetMessages();
                    showMessage('Thank you! Your message has been sent.', true);
                } else {
                    const json = await response.json();
                    if (json.error === 'rate_limited') {
                        showMessage('Please wait 1 hour before sending another message, or email admin@collimatedbeam.com directly.', false);
                    } else {
                        showMessage(json.message || 'Something went wrong. Please try again.', false);
                    }
                }
            } catch (err) {
                showMessage('There was a network error. Please try again.', false);
            } finally {
                submitBtn.disabled = false;
            }
        });

        input.addEventListener('change', (e) => showFile(e.target.files[0]));

        ['dragenter', 'dragover'].forEach((evt) =>
            dropzone.addEventListener(evt, (e) => {
                e.preventDefault();
                e.stopPropagation();
                dropzone.classList.add('border-primary');
            })
        );

        ['dragleave', 'drop'].forEach((evt) =>
            dropzone.addEventListener(evt, (e) => {
                e.preventDefault();
                e.stopPropagation();
                dropzone.classList.remove('border-primary');
            })
        );

        dropzone.addEventListener('drop', (e) => {
            e.preventDefault();
            e.stopPropagation();

            const files = e.dataTransfer.files;
            if (!files || !files.length) return;

            const file = files[0];
            const accepted = (input.getAttribute('accept') || '')
                .split(',')
                .map((type) => type.trim().toLowerCase());
            const fileExt = '.' + file.name.split('.').pop().toLowerCase();
            const isAccepted = accepted.includes(file.type.toLowerCase()) || accepted.includes(fileExt);

            if (!isAccepted) {
                resetMessages();
                fileError.textContent = `File type not allowed. Allowed: ${accepted.join(', ')}`;
                fileError.classList.remove('hidden');
                input.value = '';
                return;
            }

            input.files = files;
            showFile(file);
        });
    })();
</script>
