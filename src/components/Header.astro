---
import { type Header } from 'types';
import Action from '@components/Action.astro';
import { Icon } from 'astro-icon/components';

interface Props extends Header {
    'data-sb-field-path'?: string;
}

const { navLinks, 'data-sb-field-path': fieldPath } = Astro.props;
---

<nav
    class="sticky top-0 z-40 h-18 content-center border-b border-base-content/8 bg-base-100/80 backdrop-blur-md"
    data-sb-field-path={fieldPath}
>
    <div class="flex items-center justify-between w-full h-full px-5 mx-auto max-w-7xl sm:px-6">
        <a class="flex items-center gap-3 shrink-0" href="/">
            <img src="/logomark-dark.png" alt="" width="315" height="193" class="w-auto h-7 logo-dark" />
            <img src="/logomark-light.png" alt="" width="315" height="193" class="w-auto h-7 logo-light" />
            <span class="font-extrabold tracking-tight sm:text-lg">Collimated Beam Laser Cleaning</span>
        </a>
        <div class="flex items-center gap-2">
            {
                navLinks && navLinks.length > 0 && (
                    <>
                    <ul class="hidden lg:flex lg:flex-wrap lg:items-center lg:gap-6" data-sb-field-path=".navLinks">
                        {navLinks.map((item, index) => (
                            <li>
                                <Action
                                    action={item}
                                    class:list={[
                                        item._type === 'actionLink'
                                            ? 'text-base-content/80 no-underline transition-colors hover:text-primary'
                                            : 'px-4 py-2.5 h-auto min-h-0'
                                    ]}
                                    data-sb-field-path={`.${index}`}
                                />
                            </li>
                        ))}
                    </ul>
                    <div class="relative lg:hidden">
                        <button
                            class="inline-flex justify-center items-center w-10 h-10 relative z-2 nav-toggle"
                            aria-label="Open Menu"
                            aria-expanded="false"
                            aria-controls="nav-panel"
                        >
                            <span class="nav-toggle-icon" />
                        </button>
                        <div id="nav-panel" class="nav-panel absolute rounded-box -top-2 -right-2 z-1 shadow-xl bg-base-200 border border-base-content/10">
                            <ul class="flex flex-col px-4 pb-6 pt-14" data-sb-field-path=".navLinks">
                                {navLinks.map((item, index) => (
                                    <li>
                                        <Action
                                            action={item}
                                            class:list={[
                                                item._type === 'actionLink'
                                                    ? 'block py-2 no-underline hover:text-primary'
                                                    : 'w-full px-4 py-3.5 h-auto min-h-0'
                                            ]}
                                            data-sb-field-path={`.${index}`}
                                        />
                                    </li>
                                ))}
                                <li class="pt-3 mt-2 border-t border-base-content/10">
                                    <button type="button" class="theme-toggle btn btn-ghost btn-circle btn-sm" aria-label="Switch color theme">
                                        <Icon name="mdi:weather-sunny" class="w-5 h-5 icon-sun" />
                                        <Icon name="mdi:weather-night" class="w-5 h-5 icon-moon" />
                                        <Icon name="mdi:theme-light-dark" class="w-5 h-5 icon-auto" />
                                    </button>
                                </li>
                            </ul>
                        </div>
                    </div>
                    </>
                )
            }
            <button
                type="button"
                class:list={['theme-toggle btn btn-ghost btn-circle btn-sm', navLinks && navLinks.length > 0 && 'hidden lg:inline-flex']}
                aria-label="Switch color theme"
            >
                <Icon name="mdi:weather-sunny" class="w-5 h-5 icon-sun" />
                <Icon name="mdi:weather-night" class="w-5 h-5 icon-moon" />
                <Icon name="mdi:theme-light-dark" class="w-5 h-5 icon-auto" />
            </button>
        </div>
    </div>
</nav>

<style>
    @reference "../styles/globals.css";
    .h-18 {
        height: 4.5rem;
    }
    .nav-panel {
        @apply max-w-72 opacity-0 scale-90 origin-top-right invisible;
        width: calc(100vw - 1rem);
        transition:
            transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
            opacity 0.15s cubic-bezier(0.4, 0, 0.2, 1),
            visibility 0s 0.25s;
    }
    .nav-panel.is-visible {
        @apply scale-100 opacity-100 visible;
        transition: 0.25s;
    }
    .nav-panel li + li:has(.btn),
    .nav-panel li:has(.btn) + li {
        @apply mt-4;
    }
    .nav-toggle-icon {
        @apply block relative bg-current rounded transition;
        width: 1.5rem;
        height: 0.125rem;
    }
    .nav-toggle-icon:before,
    .nav-toggle-icon:after {
        @apply block absolute bg-current rounded transition-all;
        content: '';
        width: 1.5rem;
        height: 0.125rem;
    }
    .nav-toggle-icon:before {
        top: -0.5rem;
    }
    .nav-toggle-icon:after {
        top: 0.5rem;
    }
    .nav-toggle-icon.is-active {
        @apply bg-transparent;
    }
    .nav-toggle-icon.is-active:before {
        top: 0;
        margin-top: -0.5625rem;
        transform: translateY(0.5rem) rotate(-45deg);
    }
    .nav-toggle-icon.is-active:after {
        top: 0;
        margin-top: -0.5625rem;
        transform: translateY(0.5rem) rotate(45deg);
    }
</style>

<script>
    function navToggle() {
        const nav = document.querySelector('.nav-panel');
        const navToggleBtn = document.querySelector('.nav-toggle');
        const navToggleIcon = document.querySelector('.nav-toggle-icon');
        navToggleBtn?.addEventListener('click', () => {
            const isMenuExpanded = navToggleBtn.getAttribute('aria-expanded') === 'true';
            navToggleBtn.setAttribute('aria-expanded', isMenuExpanded ? 'false' : 'true');
            navToggleBtn.setAttribute('aria-label', isMenuExpanded ? 'Open Menu' : 'Close Menu');
            navToggleIcon?.classList.toggle('is-active');
            nav?.classList.toggle('is-visible');
        });
    }
    navToggle();
    document.addEventListener('astro:after-swap', navToggle);

    function initThemeToggle() {
        const order = ['dark', 'light', 'auto'] as const;
        document.querySelectorAll<HTMLElement>('.theme-toggle:not([data-theme-init])').forEach((btn) => {
            btn.setAttribute('data-theme-init', '');
            btn.addEventListener('click', () => {
                const html = document.documentElement;
                const mode = html.getAttribute('data-theme-mode') || 'auto';
                const next = order[(order.indexOf(mode as (typeof order)[number]) + 1) % order.length];
                const resolved =
                    next === 'auto' ? (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark') : next;
                html.setAttribute('data-theme-mode', next);
                html.setAttribute('data-theme', resolved);
                try {
                    localStorage.setItem('theme', next);
                } catch (e) {
                    /* storage unavailable */
                }
            });
        });
    }
    initThemeToggle();
    document.addEventListener('astro:after-swap', initThemeToggle);
</script>
