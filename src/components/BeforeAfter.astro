---
import { marked } from 'marked';
import { type BeforeAfterSection } from 'types';
import Section from '@components/Section.astro';

interface Props extends BeforeAfterSection {
    'data-sb-field-path'?: string;
}

const { heading, body, beforeImage, afterImage, beforeLabel = 'Before', afterLabel = 'After', ...rest } = Astro.props;

// Both source photos are ~16:10; prefer the real dimensions when Sanity provides them.
const dims = beforeImage?.dimensions || afterImage?.dimensions;
const aspectRatio = dims?.width && dims?.height ? `${dims.width} / ${dims.height}` : '16 / 10';
---

<Section {...rest} class="text-center">
    {
        heading && (
            <h2 class="text-2xl font-black sm:text-4xl text-balance" data-sb-field-path=".heading">
                {heading}
            </h2>
        )
    }
    {body && <div class:list={['mx-auto', heading && 'mt-4', 'max-w-prose markdown']} data-sb-field-path=".body" set:html={marked.parse(body)} />}

    {
        beforeImage?.src && afterImage?.src && (
            <figure
                class:list={[(heading || body) && 'mt-8', 'ba group mx-auto']}
                style={`--pos:50; aspect-ratio:${aspectRatio};`}
                data-before-after
            >
                {/* Base layer: the "after" image, always fully visible */}
                <img class="ba-img" src={afterImage.src} alt={afterImage.alt || afterLabel} draggable="false" data-sb-field-path=".afterImage" />

                {/* Overlay layer: the "before" image, clipped to the left of the handle */}
                <div class="ba-clip">
                    <img class="ba-img" src={beforeImage.src} alt={beforeImage.alt || beforeLabel} draggable="false" data-sb-field-path=".beforeImage" />
                </div>

                <span class="ba-tag ba-tag--before" data-sb-field-path=".beforeLabel">{beforeLabel}</span>
                <span class="ba-tag ba-tag--after" data-sb-field-path=".afterLabel">{afterLabel}</span>

                <div class="ba-divider" aria-hidden="true">
                    <span class="ba-knob">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="15 6 9 12 15 18" />
                            <polyline points="9 6 15 12 9 18" />
                        </svg>
                    </span>
                </div>

                <input
                    class="ba-range"
                    type="range"
                    min="0"
                    max="100"
                    value="50"
                    aria-label={`Drag to compare ${beforeLabel} and ${afterLabel}`}
                />
            </figure>
        )
    }
</Section>

<style>
    @reference "../styles/globals.css";

    .ba {
        position: relative;
        width: 100%;
        max-width: 56rem;
        overflow: hidden;
        border-radius: var(--radius-box, 1rem);
        user-select: none;
        box-shadow: 0 20px 45px -20px rgb(0 0 0 / 0.45);
        touch-action: pan-y;
        background: var(--color-base-200);
    }

    .ba-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        pointer-events: none;
    }

    /* Show the "before" image only up to the handle position */
    .ba-clip {
        position: absolute;
        inset: 0;
        clip-path: inset(0 calc(100% - var(--pos) * 1%) 0 0);
    }

    .ba-tag {
        position: absolute;
        top: 0.75rem;
        z-index: 2;
        padding: 0.25rem 0.7rem;
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        border-radius: 9999px;
        color: #fff;
        background: rgb(0 0 0 / 0.55);
        backdrop-filter: blur(4px);
        pointer-events: none;
    }
    .ba-tag--before {
        left: 0.75rem;
    }
    .ba-tag--after {
        right: 0.75rem;
    }

    .ba-divider {
        position: absolute;
        top: 0;
        bottom: 0;
        left: calc(var(--pos) * 1%);
        width: 2px;
        transform: translateX(-1px);
        background: #fff;
        z-index: 3;
        pointer-events: none;
    }

    .ba-knob {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 9999px;
        background: var(--color-primary);
        color: var(--color-primary-content);
        box-shadow: 0 2px 10px rgb(0 0 0 / 0.35);
        transition: transform 0.12s ease;
    }
    .ba:hover .ba-knob {
        transform: translate(-50%, -50%) scale(1.06);
    }

    /* Full-surface range input drives --pos; visually hidden but fully interactive + keyboard-accessible */
    .ba-range {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        margin: 0;
        z-index: 4;
        opacity: 0;
        cursor: ew-resize;
        -webkit-appearance: none;
        appearance: none;
        background: transparent;
    }
    .ba-range::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        width: 2.75rem;
        height: 100%;
        cursor: ew-resize;
    }
    .ba-range::-moz-range-thumb {
        width: 2.75rem;
        height: 100%;
        border: 0;
        background: transparent;
        cursor: ew-resize;
    }
    .ba-range:focus-visible {
        outline: none;
    }
    .ba-range:focus-visible ~ .ba-divider .ba-knob {
        outline: 3px solid var(--color-accent);
        outline-offset: 2px;
    }
</style>

<script>
    document.querySelectorAll<HTMLElement>('[data-before-after]').forEach((root) => {
        const range = root.querySelector<HTMLInputElement>('.ba-range');
        if (!range) return;
        const apply = () => root.style.setProperty('--pos', range.value);
        apply();
        range.addEventListener('input', apply);
    });
</script>
