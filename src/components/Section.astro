---
import type { Section } from 'types';
import BackgroundImage from '@components/BackgroundImage.astro';

interface Props extends Section {
    class?: string;
    'data-sb-field-path'?: string;
}

/* Per-section `theme` is intentionally not applied: sections inherit the page
   theme from <html>, which the header toggle switches between dark and light */
const { backgroundImage, width, class: className, 'data-sb-field-path': fieldPath } = Astro.props;
---

{
    width === 'inset' ? (
        <section class="w-full px-3 sm:px-6" data-width="inset" data-sb-field-path={fieldPath}>
            <div class:list={['relative py-16 mx-auto overflow-hidden max-w-7xl rounded-box border border-base-content/8 sm:py-24', className]}>
                {backgroundImage && <BackgroundImage {...backgroundImage} data-sb-field-path=".backgroundImage" />}
                <div class="relative w-10/12 mx-auto" data-reveal>
                    <slot />
                </div>
            </div>
        </section>
    ) : (
        <section class:list={['relative w-full px-3 py-16 sm:px-6 sm:py-28', className]} data-sb-field-path={fieldPath}>
            {backgroundImage && <BackgroundImage {...backgroundImage} data-sb-field-path=".backgroundImage" />}
            <div class="relative mx-auto max-w-7xl" data-reveal>
                <slot />
            </div>
        </section>
    )
}

<style>
    @reference "../styles/globals.css";
    section[data-width='inset'] + section,
    section + section[data-width='inset'] {
        @apply mt-8 sm:mt-16;
    }
</style>
