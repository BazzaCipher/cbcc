---
import { marked } from 'marked';
import { type Testimonial } from 'types';
import ResponsiveImage from '@components/ResponsiveImage.astro';

interface Props extends Testimonial {
    class?: string;
    'data-sb-field-path'?: string;
}

/* Per-card `theme` is intentionally not applied: the Beamline design keeps one
   surface across the page, so individual testimonials no longer flip light/dark */
const { quote, author, hasBorder, class: className, 'data-sb-field-path': fieldPath } = Astro.props;
---

<div
    class:list={[
        'card bg-base-200 testimonial-card',
        hasBorder !== false && 'border border-base-content/10',
        'w-full max-w-2xl border-l-2 border-l-primary/60',
        className
    ]}
    data-sb-field-path={fieldPath}
>
    <div class="text-left card-body">
        {
            author?.company && (
                <div class="mb-4 font-bold company-logo" data-sb-field-path=".author.company">
                    {author.company?.logo?.src ? (
                        <ResponsiveImage
                            _id={author.company.logo._id}
                            src={author.company.logo.src}
                            width={author.company.logo.dimensions?.width}
                            height={author.company.logo.dimensions?.height}
                            alt={author.company.logo.alt}
                            class="max-w-24"
                        />
                    ) : (
                        <span data-sb-field-path=".name">{author.company.name}</span>
                    )}
                </div>
            )
        }
        {quote && <blockquote class="text-lg sm:text-xl text-balance" data-sb-field-path=".quote" set:html={marked.parse(quote)} />}
        {
            author && (
                <div class="flex items-center gap-4 mt-4" data-sb-field-path=".author">
                    {author.image?.src && (
                        <div class="w-12 overflow-hidden rounded-full aspect-square shrink-0">
                            <ResponsiveImage
                                _id={author.image._id}
                                src={author.image.src}
                                width={48}
                                height={48}
                                alt={author.image.alt}
                                class="object-cover w-full h-full"
                            />
                        </div>
                    )}
                    <div class="font-bold">
                        <!-- prettier-ignore -->
                        <span data-sb-field-path=".name">{author.name}</span>{author.title && (<><br /><span class="font-normal text-base-content/70" data-sb-field-path=".title">{author.title}</span></>)}
                    </div>
                </div>
            )
        }
    </div>
</div>

<style>
    /* Company logos arrive in arbitrary brand colors; normalize to light monochrome on the dark card */
    :global([data-theme='dark'] .testimonial-card .company-logo img) {
        filter: brightness(0) invert(1) opacity(0.7);
    }
</style>
