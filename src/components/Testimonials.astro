---
import { marked } from 'marked';
import { type TestimonialsSection } from 'types';
import Testimonial from '@components/Testimonial.astro';
import Section from '@components/Section.astro';

interface Props extends TestimonialsSection {
    'data-sb-field-path'?: string;
}

const { heading, body, items, columns, ...rest } = Astro.props;
---

<Section {...rest}>
    {
        heading && (
            <h2 class="text-3xl font-black tracking-tight sm:text-5xl text-balance" data-sb-field-path=".heading">
                {heading}
                <span class="beam-underline" aria-hidden="true" />
            </h2>
        )
    }
    {body && <div class:list={[heading && 'mt-5', 'max-w-prose text-base-content/75 markdown']} data-sb-field-path=".body" set:html={marked.parse(body)} />}
    {
        items && items?.length > 0 && (
            <div class:list={[(heading || body) && 'mt-12', 'grid gap-6 items-stretch', columns !== 'one' && 'md:grid-cols-2']} data-sb-field-path=".items">
                {items?.map((testimonial, idx) => (
                    <div class="flex" data-reveal style={{ '--reveal-delay': `${idx * 0.08}s` }}>
                        <Testimonial {...testimonial} data-sb-field-path={`.${idx}`} class="flex-1" />
                    </div>
                ))}
            </div>
        )
    }
</Section>
