---
import { marked } from 'marked';
import { type LogosSection } from 'types';
import LogoStripAnimated from '@components/LogoStripAnimated.astro';
import LogoStripStatic from '@components/LogoStripStatic.astro';
import Section from '@components/Section.astro';

interface Props extends LogosSection {
    'data-sb-field-path'?: string;
}

const { heading, body, items, motion, ...rest } = Astro.props;
---

<Section {...rest} class="logos-section">
    {
        heading && (
            <h2 class="text-3xl font-black tracking-tight sm:text-5xl text-balance" data-sb-field-path=".heading">
                {heading}
                <span class="beam-underline" aria-hidden="true" />
            </h2>
        )
    }
    {body && <div class:list={[heading && 'mt-5', 'max-w-prose text-base-content/75 markdown']} data-sb-field-path=".body" set:html={marked.parse(body)} />}
    {
        items &&
            items.length > 0 &&
            (motion !== 'static' ? (
                <LogoStripAnimated items={items} motion={motion} class={heading || body ? 'mt-10' : undefined} data-sb-field-path=".items" />
            ) : (
                <LogoStripStatic items={items} class={heading || body ? 'mt-10' : undefined} data-sb-field-path=".items" />
            ))
    }
</Section>

<style>
    /* Client logos arrive in arbitrary brand colors; on the dark ground they are
       normalized to a quiet light monochrome so every mark stays visible */
    :global([data-theme='dark'] .logos-section img) {
        filter: brightness(0) invert(1) opacity(0.65);
        transition: filter 0.3s ease;
    }
    :global([data-theme='dark'] .logos-section img:hover) {
        filter: brightness(0) invert(1) opacity(1);
    }
</style>
